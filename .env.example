# Application
APP_NAME=ASOC PI Readiness & Manager Sign-Off
APP_SECRET=replace-with-a-long-random-secret
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=ChangeMe123!
APP_MANAGER_NAME=Rezaan Marlie
APP_MANAGER_EMAIL=
DATA_DIR=./data

# Jira connection
# Set MOCK_MODE=false when connecting to Jira.
MOCK_MODE=true
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_VERSION=3
# basic = email + API token (Jira Cloud); bearer = PAT (often Jira Data Center)
JIRA_AUTH_MODE=basic
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-api-token-or-pat
JIRA_VERIFY_SSL=true
JIRA_TIMEOUT_SECONDS=30
# Bulk scan controls
JIRA_SCAN_MAX_RESULTS=2000
JIRA_SCAN_BATCH_SIZE=50
SCAN_CACHE_SECONDS=180

# Default query values
JIRA_PROJECT=NMGOS
DEFAULT_PI_VALUE=PI26
DEFAULT_SCRUM_MASTER_ID=70121:c296bec5-b136-48b7-9345-a1e16f9f38dc
DEFAULT_SCRUM_MASTER_NAME=
DEFAULT_PRIORITY=Critical
MANAGER_SIGNOFF_DEADLINE=2026-07-07T16:00:00+02:00

# Optional Jira write-back
ENABLE_JIRA_WRITEBACK=false
SIGNOFF_LABEL_PREFIX=manager-signoff
